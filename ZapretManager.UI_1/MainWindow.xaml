<Window x:Class="ZapretManager.UI_1.MainWindow"
        
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ZapretManager.UI_1"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        
        mc:Ignorable="d"
        Background="Transparent"
        Title="MainWindow"
        
        WindowStyle="None"
        
        MinHeight="450" MinWidth="800"
        MaxHeight="500" MaxWidth="1000"
        
        Height="450" Width="800"
        xmlns:converters="clr-namespace:ZapretManager.UI_1.Converters"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors">

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding RunApplicationCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>
    
    <Window.Resources>
        <converters:ModeToImageConverter x:Key="ModeToImageConverter"/>
    </Window.Resources>
    
    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/ZapretManager.UI_1;component/Assets/Main.png" Stretch="UniformToFill"/>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition Width="*"></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            
            <TextBlock Style="{StaticResource HeaderTextBlock}" 
                        Grid.Column="0" Text="{Binding ModeName, StringFormat='{}{0} Mode'}" HorizontalAlignment="Left" 
                        VerticalAlignment="Center" Margin="2.5,0,0,0" Padding="10"/>

            <StackPanel Grid.Column="2" Margin="0,6,14,5" Orientation="Horizontal">
                <Button Command="{Binding MinimizeWindowCommand}" Style="{StaticResource MinimizeButton}" Grid.Column="2" MinHeight="15" MinWidth="15" HorizontalAlignment="Left" 
VerticalAlignment="Center" Margin="0,0,12,0"/>
                <Button Command="{Binding CloseWindowCommand}" Style="{StaticResource CloseButton}" Grid.Column="2" MinHeight="15" MinWidth="15" HorizontalAlignment="Left" 
VerticalAlignment="Center"/>
            </StackPanel>

        </Grid>

        <Grid Grid.Row="1">
            <Border  Height="2" Background="#FF6B5B" CornerRadius="1" Margin="10,0,10,10" 
                VerticalAlignment="Top" HorizontalAlignment="Stretch"/>
        </Grid>

        <Grid Grid.Row="2" Margin="0,15,0,0">
            
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
            </Grid.RowDefinitions>

            <TextBlock Style="{StaticResource BasicTextBlock}" Grid.Row="0" Text="{Binding Mode, StringFormat='{}{0} Mode'}" 
                HorizontalAlignment="Left" VerticalAlignment="Center" Margin="2.5,0,0,0" Padding="10"/>

            <StackPanel Grid.Row="1"  Orientation="Horizontal" HorizontalAlignment="Left">
                <TextBlock Style="{StaticResource BasicTextBlock}" Grid.Row="1" 
                            Text="{Binding Mode, StringFormat='Actuality {0} :'}" HorizontalAlignment="Center" 
                            VerticalAlignment="Center" Margin="2.5,0,0,0" Padding="10"/>
                <Ellipse Width="8" Height="8" Fill="#FFFFFF" Margin="5,0,0,0"/>
                <TextBlock Style="{StaticResource BasicTextBlock}" Grid.Row="1" HorizontalAlignment="Center" 
                            VerticalAlignment="Center" Padding="10" Margin="7,0,0,0"> 
                    <Run Text="{Binding ActualityName, Mode=OneWay}" Foreground="{Binding RelevantColor}"/>
                    <Run Text="{Binding HintStatus}" Foreground="#BEBEBE"/>
                </TextBlock>
            </StackPanel>

            <StackPanel Grid.Row="2"  Orientation="Horizontal" HorizontalAlignment="Left">
                <TextBlock Style="{StaticResource BasicTextBlock}" Grid.Row="1" 
                            Text="{Binding ModeName, StringFormat='Version {0} :'}" HorizontalAlignment="Center" 
                            VerticalAlignment="Center" Margin="2.5,0,0,0" Padding="10"/>
                <Ellipse Width="8" Height="8" Fill="#FFFFFF" Margin="5,0,0,0"/>
                <TextBlock Style="{StaticResource BasicTextBlock}" Grid.Row="1" Text="{Binding AppVersion}" HorizontalAlignment="Center" 
                            VerticalAlignment="Center" Margin="7,0,0,0" Padding="10" Foreground="{Binding VersionColor}"/>
            </StackPanel>

        </Grid>

        <Grid Grid.Row="4" Margin="15,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
            </Grid.ColumnDefinitions>

            <Button x:Name="SwitchModeButton" Style="{StaticResource ModeButton}" 
                    Margin="0,0,15,0" Command="{Binding SwitchModeCommand}"
                    Grid.Column="0" Padding="10" MinWidth="190" MinHeight="60">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width ="Auto"/>
                        <ColumnDefinition Width ="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Image Grid.Column="0" Height="30" Width="30"
                           Source="{Binding Mode, Converter={StaticResource ModeToImageConverter}}"
                           Stretch="UniformToFill" HorizontalAlignment="Left"/>
                    <TextBlock Grid.Column="1" Style="{StaticResource BasicTextBlock}" 
                           Foreground="Black" Text="{Binding ModeName}" HorizontalAlignment="Right" 
                           VerticalAlignment="Center" Padding="7"/>
                </Grid>
            </Button>

            <Button Style="{StaticResource MainButton}" Margin="0,0,15,0"
                Grid.Column="1" Padding="10" MinWidth="150" MinHeight="60" Command="{Binding UpdateCommand}">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width ="Auto"/>
                        <ColumnDefinition Width ="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Image Grid.Column="0" Height="30" Width="30"
                        Source="/ZapretManager.UI_1;component/Assets/Logos/bigtop_updates.png"
                        Stretch="UniformToFill" HorizontalAlignment="Left"/>
                    <TextBlock Grid.Column="1" Style="{StaticResource HeaderTextBlock}" FontSize="18"  Text="Update" HorizontalAlignment="Right" 
                        VerticalAlignment="Center" Padding="7"/>
                </Grid>
            </Button>

            <Button Style="{StaticResource MainButton}" Command="{Binding SettingsOpenCommand}"
                Grid.Column="2" Padding="10" MinWidth="150" MinHeight="60">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width ="Auto"/>
                        <ColumnDefinition Width ="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Image Grid.Column="0" Height="30" Width="30"
                        Source="/ZapretManager.UI_1;component/Assets/Logos/manufacturing.png"
                        Stretch="UniformToFill" HorizontalAlignment="Left"/>
                    <TextBlock Grid.Column="1" Style="{StaticResource HeaderTextBlock}" FontSize="18"  Text="Settings" HorizontalAlignment="Right" 
                        VerticalAlignment="Center" Padding="7"/>
                </Grid>
            </Button>
        </Grid>
    </Grid>

</Window>

    