<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.modernwpf.com/2019"
    xmlns:local="clr-namespace:ZapretManager.UI_1">
    

    <!-- Normal -->
    <SolidColorBrush x:Key="ButtonBackground" Color="#2B2B2B" />
    <SolidColorBrush x:Key="ButtonForeground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="ButtonBorderBrush" Color="Transparent" />

    <!-- PointOver -->
    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#3D3D3D" />
    <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent" />
    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#FFFFFF" />

    <!-- Pressed -->
    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#1F1F1F" />
    <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="Transparent" />
    <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#CCCCCC" />
    <SolidColorBrush x:Key="DropDownButtonForegroundSecondaryPressed" Color="#AAAAAA" />

    <!-- Disabled -->
    <SolidColorBrush x:Key="ButtonBackgroundDisabled" Color="#1A1A1A" />
    <SolidColorBrush x:Key="ButtonBorderBrushDisabled" Color="Transparent" />
    <SolidColorBrush x:Key="ButtonForegroundDisabled" Color="#555555" />

    <Style x:Key="BasicPresent" TargetType="ui:FlyoutPresenter">
        <Setter Property="Background" Value="#23314F" />
        <Setter Property="Padding" Value="2" />
        <Setter Property="CornerRadius" Value="5" />
        <Setter Property="BorderBrush" Value="White" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="BasicDropDown" TargetType="ui:DropDownButton">
        <Setter Property="Background" Value="#1B2230" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="BorderBrush" Value="#DADADA" />
        <Setter Property="BorderThickness" Value="1" />
        
        <Setter Property="MinWidth" Value="150"/>

        <Setter Property="FontFamily" Value="{StaticResource OutfitRegular}"/>
    </Style>

</ResourceDictionary>