<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.modernwpf.com/2019"
    xmlns:local="clr-namespace:ZapretManager.UI_1">

    <SolidColorBrush x:Key="ToggleSwitchFillOff" Color="#FF2C2C2C" />
    <SolidColorBrush x:Key="ToggleSwitchStrokeOff" Color="#FF555555" />

    <SolidColorBrush x:Key="ToggleSwitchFillOn" Color="#FF6B5B" />
    <SolidColorBrush x:Key="ToggleSwitchStrokeOn" Color="#FF6B5B" />

    <SolidColorBrush x:Key="ToggleSwitchKnobFillOff" Color="#FFAAAAAA" />
    <SolidColorBrush x:Key="ToggleSwitchKnobFillOn" Color="#FFFFFFFF" />

    <SolidColorBrush x:Key="ToggleSwitchFillOffPointerOver" Color="#FF3A3A3A" />
    <SolidColorBrush x:Key="ToggleSwitchFillOnPointerOver" Color="#FF7E6E6E" />
    <SolidColorBrush x:Key="ToggleSwitchKnobFillOffPointerOver" Color="#FFCCCCCC" />
    <SolidColorBrush x:Key="ToggleSwitchKnobFillOnPointerOver" Color="#FFFFFFFF" />

    <SolidColorBrush x:Key="ToggleSwitchFillOffPressed" Color="#FF252525" />
    <SolidColorBrush x:Key="ToggleSwitchFillOnPressed" Color="#FF5A4B4B" />

    <SolidColorBrush x:Key="ToggleSwitchFillOffDisabled" Color="#FF1F1F1F" />
    <SolidColorBrush x:Key="ToggleSwitchFillOnDisabled" Color="#FF3F3F3F" />
    <SolidColorBrush x:Key="ToggleSwitchKnobFillOffDisabled" Color="#FF666666" />
    <SolidColorBrush x:Key="ToggleSwitchKnobFillOnDisabled" Color="#FF999999" />

    <SolidColorBrush x:Key="ToggleSwitchContainerBackground" Color="Transparent" />

    <Style x:Key="ToggleZapret" TargetType="ToggleButton" BasedOn="{StaticResource {x:Type ToggleButton}}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="border" 
                        CornerRadius="5"
                        Background="#31398D"
                        Padding="10">

                        <ContentPresenter/>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#FF6B5B" />
                        </Trigger>

                        <Trigger Property="IsChecked" Value="False">
                            <Setter TargetName="border" Property="Background" Value="#31398D" />
                        </Trigger>

                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="True"/>
                                <Condition Property="IsMouseOver" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="border" Property="Background" Value="#FF4E3B" />
                        </MultiTrigger>

                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="False"/>
                                <Condition Property="IsMouseOver" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="border" Property="Background" Value="#4951B1" />
                        </MultiTrigger>
                        
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SwitchToggleZapret" TargetType="ui:ToggleSwitch" BasedOn="{StaticResource {x:Type ui:ToggleSwitch}}">
        <Setter Property="FontFamily" Value="{StaticResource OutfitRegular}"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="IsOn" Value="False"/>
        <Setter Property="Foreground" Value="#FF8E24"/>
        <Setter Property="OnContent" Value="(Enabled)"/>
        <Setter Property="OffContent" Value="(Disabled)"/>
        <Setter Property="Padding" Value="10"/>
    </Style>
    
</ResourceDictionary>